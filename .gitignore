# ── Secrets — never commit these ──────────────────────────────────────────────

# ESP32 node secrets (WiFi, master key, MQTT credentials)
firmware/access_node/secrets.h

# Kiosk Python app secrets (master key)
apps/kiosk_station/secrets.py

# Kiosk station writer secrets (master key for Arduino firmware)
apps/kiosk_station/station_writer/secrets_station.h

# Firebase Admin SDK service account credential
services/rpi_bridge/service-account.json
**/service-account.json

# Bridge environment file
services/rpi_bridge/.env

# Web app environment files (real values should not be committed)
apps/web_app/.env
apps/web_app/.env.local

